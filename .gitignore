# =========================================================
# HMS (FastAPI + React/Vite) - Repo-wide .gitignore
# =========================================================

# ---- Secrets / environment ----
.env
.env.*
!.env.example
!.env.*.example

# ---- Python (backend) ----
__pycache__/
*.py[cod]
*.pyd
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/
env/
*.venv/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# Build / packaging
build/
dist/
*.egg-info/

# ---- Backend runtime artifacts ----
backend/uploads/
uploads/

# ---- Node / frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

dist/
dist-ssr/
*.local

# Vite / cache
.vite/

# ---- Logs ----
logs/
*.log

# ---- OS / Editor ----
.DS_Store
Thumbs.db
Desktop.ini

.idea/

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# ---- Misc ----
*.swp
*.swo
*.swn
desing
